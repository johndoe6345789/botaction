        }
      }
    },
    {
      "id": "parse-params",
      "name": "Parse Params",
      "type": "diter.action",
      "typeVersion": 1,
      "position": [
        760,
        200
      ],
      "parameters": {
        "action": "parse_params",
        "text": "@params_text",
        "outputs": {
          "dict_b64": "dict_b64",
          "needs_key": "needs_key"
        }
      }
    },
    {
      "id": "decode-dict",
      "name": "Decode Dict",
      "type": "diter.action",
      "typeVersion": 1,
      "position": [
        1040,
        200
      ],
      "parameters": {
        "action": "decode_dict",
        "dict_b64": "@dict_b64",
        "outputs": {
          "dict_bytes": "dict_bytes"
        }
      }
    },
    {
      "id": "read-binz",
      "name": "Read Binz",
      "type": "diter.action",
      "typeVersion": 1,
      "position": [
        1320,
        200
      ],
      "parameters": {
        "action": "read_bytes",
        "path": "@binz_path",
        "outputs": {
          "bytes": "binz_bytes"
        }
      }
    },
    {
      "id": "read-key-source",
      "name": "Read Key Source",
      "type": "diter.action",
      "typeVersion": 1,
      "position": [
        1600,
        160
      ],
      "parameters": {
        "action": "read_text",
        "path": "@key_source_path",
        "optional": true,
        "outputs": {
          "text": "key_source_text"
        }
      }
    },
    {
      "id": "extract-key",
      "name": "Extract Key",
      "type": "diter.action",
      "typeVersion": 1,
      "position": [
        1880,
        160
      ],
      "parameters": {
        "action": "extract_key_hex",
